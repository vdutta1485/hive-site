# ======================
# Hive — Environment Variables
# ======================
# Copy this file to .env and fill in the values.

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database
# On Vercel, use the Supabase connection-pooler URI (Dashboard → Connect →
# "Transaction pooler", port 6543). For local dev use any Postgres URL.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Supabase Storage (image uploads — required on Vercel since its disk is read-only)
# Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public storage bucket name (create it in Dashboard → Storage). Defaults to "listings".
SUPABASE_STORAGE_BUCKET=listings
# Private bucket for sensitive uploads (applicant photo IDs). Defaults to "applicant-ids".
SUPABASE_PRIVATE_BUCKET=applicant-ids
# On-upload image optimization (admin listing photos -> resized WebP). Defaults shown.
IMAGE_MAX_WIDTH=2000
IMAGE_WEBP_QUALITY=80

# Session Secret (generate a random string — keep this private)
SESSION_SECRET=change-me-to-a-random-string

# Email Notifications (for application and inquiry forms) — Resend.
# Get an API key at resend.com and verify the sending domain (hiveny.com) there.
RESEND_API_KEY=your-resend-api-key
# Address all outbound mail is sent from (must be on a Resend-verified domain)
MAIL_FROM=Hive <vineet.dutta@hiveny.com>
# Master recipient for submitted inquiry/application details
NOTIFY_EMAIL=vineet.dutta@hiveny.com

# Stripe (paid tenant application — $20 fee via embedded Checkout)
# Dashboard → Developers → API keys. Use TEST keys (sk_test_… / pk_test_…) for the
# sandbox. The secret key stays server-side; the publishable key is sent to the browser.
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
# Application fee in cents (defaults to 2000 = $20.00 if unset).
APPLICATION_FEE_CENTS=2000

# Google Drive API (for bulk image import from Drive folders)
GOOGLE_API_KEY=your-google-api-key

# Google Maps JS API key for the listing "approximate area" map (radius circle).
# Needs the "Maps JavaScript API" + "Geocoding API" enabled with billing.
# If unset, the listing page falls back to a neighborhood-level embedded map.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Reviews Widget (homepage testimonials)
GOOGLE_PLACES_API_KEY=your-places-api-key
GOOGLE_PLACE_ID=your-google-place-id
