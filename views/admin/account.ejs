<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hive Admin - Account</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --ink: #1a1a18;
      --cream: #f5f2ed;
      --accent: #d4920b;
      --accent-dark: #b87d09;
      --white: #fefdfb;
      --muted: #8a8378;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--cream);
      color: var(--ink);
      min-height: 100vh;
    }

    /* --- Nav Bar --- */
    .admin-nav {
      background: var(--ink);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      height: 56px;
    }
    .admin-nav-brand {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--white);
      text-decoration: none;
      letter-spacing: 1px;
    }
    .admin-nav-brand span {
      font-family: 'DM Sans', sans-serif;
      font-size: 11px;
      font-weight: 500;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-left: 10px;
    }
    .admin-nav-right {
      display: flex;
      align-items: center;
      gap: 20px;
      font-size: 14px;
    }
    .admin-nav-right .admin-greeting { color: #b0ada6; }
    .admin-nav-right a {
      color: var(--accent);
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
    }
    .admin-nav-right a:hover { color: var(--accent-dark); }

    /* --- Card --- */
    .account-wrap {
      max-width: 480px;
      margin: 48px auto;
      padding: 0 24px;
    }
    .back-link {
      display: inline-block;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 16px;
    }
    .back-link:hover { color: var(--ink); }

    .account-card {
      background: var(--white);
      border: 1px solid #e0ddd7;
      border-radius: 8px;
      padding: 36px 32px;
      box-shadow: 0 2px 12px rgba(26, 26, 24, 0.06);
    }
    .account-card h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 600;
      margin-bottom: 6px;
    }
    .account-card .subtitle {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 24px;
    }

    .error-message {
      background: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
      border-radius: 6px;
      padding: 12px 16px;
      font-size: 14px;
      margin-bottom: 20px;
    }
    .success-message {
      background: #f0fdf4;
      color: #166534;
      border: 1px solid #bbf7d0;
      border-radius: 6px;
      padding: 12px 16px;
      font-size: 14px;
      margin-bottom: 20px;
    }

    .form-group { margin-bottom: 20px; }
    .form-group label {
      display: block;
      font-size: 13px;
      font-weight: 500;
      color: var(--ink);
      margin-bottom: 6px;
    }
    .form-group input {
      width: 100%;
      padding: 10px 14px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      border: 1px solid #d4d0c8;
      border-radius: 6px;
      background: var(--white);
      color: var(--ink);
      transition: border-color 0.2s;
    }
    .form-group input:focus {
      outline: none;
      border-color: var(--accent-dark);
      box-shadow: 0 0 0 3px rgba(230, 210, 0, 0.15);
    }
    .form-hint {
      font-size: 12px;
      color: var(--muted);
      margin-top: 6px;
    }

    .btn-primary {
      width: 100%;
      padding: 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      font-weight: 600;
      background: var(--ink);
      color: var(--white);
      border: none;
      border-radius: 6px;
      cursor: pointer;
      transition: background-color 0.2s;
      margin-top: 8px;
    }
    .btn-primary:hover { background: #333330; }
  </style>
</head>
<body>
  <!-- Nav Bar -->
  <nav class="admin-nav">
    <a href="/admin/dashboard" class="admin-nav-brand">Hive <span>Admin</span></a>
    <div class="admin-nav-right">
      <span class="admin-greeting">Hello, <%= adminName %></span>
      <a href="/admin/logout">Logout</a>
    </div>
  </nav>

  <div class="account-wrap">
    <a href="/admin/dashboard" class="back-link">&larr; Back to dashboard</a>

    <div class="account-card">
      <h2>Change Password</h2>
      <p class="subtitle">Update the password for your admin account.</p>

      <% if (error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="success-message"><%= success %></div>
      <% } %>

      <form method="POST" action="/admin/account/password">
        <div class="form-group">
          <label for="current_password">Current password</label>
          <input type="password" id="current_password" name="current_password" required autocomplete="current-password">
        </div>
        <div class="form-group">
          <label for="new_password">New password</label>
          <input type="password" id="new_password" name="new_password" required autocomplete="new-password" minlength="8">
          <p class="form-hint">At least 8 characters.</p>
        </div>
        <div class="form-group">
          <label for="confirm_password">Confirm new password</label>
          <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password" minlength="8">
        </div>
        <button type="submit" class="btn-primary">Update Password</button>
      </form>
    </div>
  </div>
</body>
</html>
